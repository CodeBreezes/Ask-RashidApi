@{
    var activeTabName = ViewBag.ActiveTabName as string ?? "";
    var username = Context.Session.GetString("User") ?? "Admin"; // get from session
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Responsive Admin Panel</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <link href="~/stylesheet.css" rel="stylesheet" />
</head>
<body>
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <img src="https://i.pravatar.cc/50?img=1" class="rounded-circle me-2" alt="User" />
            <div>
                <div class="sidebar-title">@username</div>
                <div class="sidebar-subtitle">Administrator</div>
            </div>
        </div>

        <div class="sidebar-menu flex-grow-1">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a href="/Admin/UserProfile" class="nav-link @(activeTabName == "UserProfile" ? "active" : "")">
                        <i class="fas fa-user"></i> User Profile
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/Service/Index" class="nav-link @(activeTabName == "Services" ? "active" : "")">
                        <i class="fas fa-cogs"></i> All Services
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/Bookings/Index" class="nav-link @(activeTabName == "Booking" ? "active" : "")">
                        <i class="fas fa-envelope"></i> All Bookings
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/Bookings/Payment" class="nav-link @(activeTabName == "Payment" ? "active" : "")">
                        <i class="fas fa-credit-card"></i> All Payments
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/Feedbacks/Index" class="nav-link @(activeTabName == "Feedback" ? "active" : "")">
                        <i class="fas fa-comments"></i> All Feedback
                    </a>
                </li>
            </ul>
        </div>

        <div class="sidebar-footer">
            <a href="/UserAccount/Logout" class="btn btn-pro">
                <i class="fas fa-sign-out-alt me-2"></i> Logout
            </a>
        </div>
    </div>

    <div id="page-content-wrapper">
        <nav class="navbar navbar-expand navbar-light border-bottom">
            <div class="container-fluid">
                <button class="btn btn-primary d-lg-none" id="sidebar-toggle-btn">
                    <i class="fa fa-bars"></i>
                </button>

                <div class="search-container d-none d-md-flex ms-3">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" class="form-control search-input" placeholder="Search..." />
                </div>

                <div class="d-flex align-items-center ms-auto">
                    <div class="dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                            <span class="me-2 d-none d-md-inline">@username</span>
                            <img src="https://i.pravatar.cc/50?img=1" class="rounded-circle profile-img" alt="Profile" />
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/Admin/UserProfile">Profile</a></li>
                            <li><a class="dropdown-item" href="#">Settings</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" href="/UserAccount/Logout">Logout</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>

        <main class="py-4">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById("sidebar-toggle-btn").addEventListener("click", function () {
            document.getElementById("sidebar").classList.toggle("show");
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>

